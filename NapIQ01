        <div style={{margin:"1.5rem 0",padding:"1rem 1.25rem",borderRadius:10,border:`1.5px solid ${interp.color}`}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
            <span style={{fontSize:13,color:"#555577"}}>Puntaje total</span>
            <span style={{fontSize:28,fontWeight:500,color:interp.color}}>{score} / {scale.max}</span>
          </div>
          <div style={{padding:"5px 12px",borderRadius:20,background:interp.color+"22",display:"inline-block",fontSize:13,color:interp.color,fontWeight:500,marginBottom:6}}>{interp.label}</div>
