        <div><h2 style={{fontSize:18,fontWeight:500,margin:0}}>{patient.name}</h2><p style={{fontSize:13,color:"#555577",margin:0}}>{patient.age?`${patient.age} años · `:""}{patient.evaluations?.length||0} evaluaciones</p></div>
      </div>
      {Object.values(le).length>0&&(<div style={{marginBottom:"1.5rem"}}><h3 style={{fontSize:15,fontWeight:500,marginBottom:10}}>Últimos resultados</h3>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(130px,1fr))",gap:8}}>
          {Object.values(le).map(e=>{const ip=SCALES[e.scaleId]?.interpret(e.score);return(<div key={e.scaleId} style={{padding:"0.75rem 1rem",background:"#f4f4f8",borderRadius:10,borderLeft:`3px solid ${ip?.color||"#888"}`}}>
            <p style={{fontSize:11,color:"#555577",margin:"0 0 3px"}}>{e.scaleName.split("(")[0].trim()}</p>
            <p style={{fontSize:22,fontWeight:500,margin:"0 0 2px",color:ip?.color}}>{e.score}<span style={{fontSize:12,color:"#999"}}>/{e.max}</span></p>
            <p style={{fontSize:11,margin:0,color:ip?.color}}>{e.label}</p>
          </div>);})}
        </div>
      </div>)}
      {Object.entries(cd).some(([,v])=>v.length>1)&&(<div style={{marginBottom:"1.5rem"}}><h3 style={{fontSize:15,fontWeight:500,marginBottom:10}}>Progreso en el tiempo</h3>
        {Object.entries(cd).map(([sid,vals])=>vals.length>1&&(<div key={sid} style={{marginBottom:10,padding:"0.875rem 1rem",background:"#f4f4f8",borderRadius:10,border:"0.5px solid #e0e0ee"}}>
          <p style={{fontSize:13,fontWeight:500,marginBottom:8}}>{SCALES[sid]?.name.split("(")[0].trim()}</p>
          <div style={{display:"flex",alignItems:"flex-end",gap:6,height:64}}>
            {vals.map((v,i)=>{const pct=v.score/v.max;const col=SCALES[sid]?.interpret(v.score)?.color||"#888";return(<div key={i} style={{display:"flex",flexDirection:"column",alignItems:"center",gap:3,flex:1}}>
