    doc.text("Llena este diario cada mañana al despertar, recordando la noche anterior. No lo llenes durante la noche.",14,y);y+=6;
  }
  if(y>240){doc.addPage();pdfFooter(doc,doc.internal.pages.length-1,doc.internal.pages.length);y=20;}
  y+=4;pdfSetColor(doc,"#F0FFF8","fill");doc.roundedRect(14,y,W-28,16,2,2,"F");
  pdfSetColor(doc,GREEN,"fill");doc.roundedRect(14,y,3,16,1,1,"F");
  doc.setFontSize(9);doc.setFont("helvetica","bold");pdfSetColor(doc,GREEN,"text");doc.text("Recuerda esta semana:",20,y+6);
  doc.setFontSize(9);doc.setFont("helvetica","normal");pdfSetColor(doc,"#1A5C44","text");
  const ml=doc.splitTextToSize(motivations[session.n]||"¡Sigue adelante!",W-34);doc.text(ml,20,y+11);y+=18;
  const tp=doc.internal.pages.length-1;for(let p=1;p<=tp;p++){doc.setPage(p);pdfFooter(doc,p,tp);}
  doc.save(`NapIQ_Semana${session.n}_${patient.name.replace(/ /g,"_")}.pdf`);
}

