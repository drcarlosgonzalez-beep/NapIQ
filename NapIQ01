      ))}
    </div>
  );
}

function PatientReport({patient,onBack,onStartTCCI,onScaleSelect}){
  const [aiRep,setAiRep]=useState("");const [load,setLoad]=useState(false);
  const le={};patient.evaluations?.forEach(e=>{le[e.scaleId]=e;});
  async function gen(){
    setLoad(true);
    const sum=Object.values(le).map(e=>`${e.scaleName}: ${e.score}/${e.max} — ${e.label}`).join("\n");
    try{const r=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,system:"Especialista en medicina del sueño. Reporte clínico conciso en español. Formato: 1) Síntesis diagnóstica, 2) Correlación ICSD-3 TR/DSM-5-TR, 3) Estratificación de riesgo, 4) Abordaje terapéutico (TCC-I paquete óptimo Furukawa 2024 si aplica). Máximo 380 palabras.",messages:[{role:"user",content:`Paciente: ${patient.name}, ${patient.age||"?"}a.\n${sum}\nGenera reporte clínico.`}]})});
    const d=await r.json();setAiRep(d.content?.[0]?.text||"Error.");}catch{setAiRep("Error de conexión.");}
    setLoad(false);
