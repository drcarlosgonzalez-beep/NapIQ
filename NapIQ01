        {!aiRep&&Object.values(le).length===0&&<p style={{fontSize:13,color:"#999"}}>Completa al menos una escala para generar el reporte.</p>}
      </div>
      <div><h3 style={{fontSize:15,fontWeight:500,marginBottom:10}}>Aplicar escala</h3>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(160px,1fr))",gap:8}}>
          {Object.values(SCALES).map(s=>(<button key={s.id} onClick={()=>onScaleSelect(s)} style={{padding:"0.75rem 1rem",textAlign:"left",background:"#f4f4f8",borderRadius:10,border:"0.5px solid #e0e0ee",cursor:"pointer",fontSize:13,fontWeight:500,color:"#1a1a2e"}}>
            {s.name.split("(")[0].trim()}<span style={{display:"block",fontSize:11,color:"#999",fontWeight:400}}>{s.name.match(/\(([^)]+)\)/)?.[1]||""}</span>
          </button>))}
        </div>
      </div>
    </div>
  );
}

// ── MAIN ──────────────────────────────────────────────────────────────────────
function App(){
  const [tab,setTab]=useState("patients");
  const [patients,setPatients]=useState(loadP);
  const [selPt,setSelPt]=useState(null);
  const [activeScale,setActiveScale]=useState(null);
  const [showNew,setShowNew]=useState(false);
  const [newName,setNewName]=useState("");const [newAge,setNewAge]=useState("");
  const [view,setView]=useState("list");
  const [diagCat,setDiagCat]=useState("Todos");const [diagSearch,setDiagSearch]=useState("");
  const [expDx,setExpDx]=useState(null);
  const [glossSearch,setGlossSearch]=useState("");
  const [fVals,setFVals]=useState({});const [fRes,setFRes]=useState({});

  function addPt(){if(!newName.trim())return;const p={id:Date.now(),name:newName.trim(),age:newAge,evaluations:[],createdAt:new Date().toISOString()};const u=[...patients,p];setPatients(u);saveP(u);setNewName("");setNewAge("");setShowNew(false);}
  function handleScaleDone(result){const u=patients.map(p=>{if(p.id!==selPt.id)return p;return{...p,evaluations:[...(p.evaluations||[]),result]};});setPatients(u);saveP(u);setSelPt(u.find(p=>p.id===selPt.id));setView("report");setActiveScale(null);}
  const fDx=DX.filter(d=>(diagCat==="Todos"||d.cat===diagCat)&&(!diagSearch||d.name.toLowerCase().includes(diagSearch.toLowerCase())));
  const fGlos=GLOS.filter(g=>!glossSearch||g.t.toLowerCase().includes(glossSearch.toLowerCase())||g.d.toLowerCase().includes(glossSearch.toLowerCase()));
  function calcF(fid){const f=FORMULAS.find(x=>x.id===fid);const r=f.calc(fVals[fid]||{});setFRes({...fRes,[fid]:r});}

  const TABS=[{id:"patients",label:"Pacientes",icon:"ti-users"},{id:"scales",label:"Escalas",icon:"ti-clipboard-list"},{id:"diagnostics",label:"Diagnósticos",icon:"ti-stethoscope"},{id:"tccd",label:"TCC-I",icon:"ti-brain"},{id:"formulas",label:"Fórmulas",icon:"ti-calculator"},{id:"glossary",label:"Glosario",icon:"ti-book"}];

  return(
    <div style={{fontFamily:"var(--font-sans)",color:"#1a1a2e",maxWidth:720,margin:"0 auto"}}>
      <div style={{display:"flex",alignItems:"center",gap:10,padding:"1rem 0 0.5rem",borderBottom:"0.5px solid #e0e0ee",marginBottom:"1rem"}}>
        <div style={{width:36,height:36,borderRadius:10,background:BRAND,display:"flex",alignItems:"center",justifyContent:"center"}}><i className="ti ti-moon" style={{color:"#fff",fontSize:18}}></i></div>
        <div><h1 style={{fontSize:20,fontWeight:500,margin:0,letterSpacing:-0.3}}>NapIQ</h1><p style={{fontSize:11,color:"#555577",margin:0}}>Plataforma clínico-diagnóstica · ICSD-3 TR · DSM-5-TR · Furukawa 2024</p></div>
      </div>
      <div style={{display:"flex",gap:0,marginBottom:"1.25rem",borderBottom:"0.5px solid #e0e0ee",overflowX:"auto"}}>
        {TABS.map(t=>(<button key={t.id} onClick={()=>{setTab(t.id);setView("list");setActiveScale(null);}} style={{padding:"8px 11px",fontSize:12,border:"none",borderBottom:tab===t.id?`2px solid ${BRAND}`:"2px solid transparent",background:"none",color:tab===t.id?BRAND:"#555577",cursor:"pointer",fontWeight:tab===t.id?500:400,display:"flex",alignItems:"center",gap:4,whiteSpace:"nowrap"}}><i className={`ti ${t.icon}`} style={{fontSize:14}}></i>{t.label}</button>))}
      </div>

      {tab==="patients"&&view==="list"&&(<div>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"1rem"}}>
          <h2 style={{fontSize:16,fontWeight:500,margin:0}}>Pacientes</h2>
          <button onClick={()=>setShowNew(true)} style={{padding:"7px 14px",fontSize:13,borderRadius:8,border:"0.5px solid #c8c8dd",background:"#fff",cursor:"pointer",display:"flex",alignItems:"center",gap:5}}><i className="ti ti-plus" style={{fontSize:14}}></i>Nuevo paciente</button>
        </div>
        {showNew&&(<div style={{padding:"1rem",background:"#f4f4f8",borderRadius:10,border:"0.5px solid #e0e0ee",marginBottom:"1rem"}}>
          <p style={{fontSize:14,fontWeight:500,marginBottom:10}}>Nuevo paciente</p>
          <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
            <input value={newName} onChange={e=>setNewName(e.target.value)} placeholder="Nombre completo" style={{flex:2,minWidth:160,padding:"7px 10px",fontSize:13,borderRadius:8,border:"0.5px solid #c8c8dd",background:"#fff",color:"#1a1a2e"}} onKeyDown={e=>e.key==="Enter"&&addPt()}/>
            <input value={newAge} onChange={e=>setNewAge(e.target.value)} placeholder="Edad" type="number" style={{flex:1,minWidth:70,padding:"7px 10px",fontSize:13,borderRadius:8,border:"0.5px solid #c8c8dd",background:"#fff",color:"#1a1a2e"}}/>
            <button onClick={addPt} style={{padding:"7px 14px",fontSize:13,borderRadius:8,border:"none",background:BRAND,color:"#fff",cursor:"pointer"}}>Agregar</button>
            <button onClick={()=>setShowNew(false)} style={{padding:"7px 10px",fontSize:13,borderRadius:8,border:"0.5px solid #c8c8dd",background:"#fff",cursor:"pointer"}}>Cancelar</button>
          </div>
        </div>)}
        {patients.length===0&&<p style={{fontSize:14,color:"#999",textAlign:"center",padding:"2.5rem 0"}}>Sin pacientes registrados. Agrega el primero.</p>}
        {patients.map(pt=>(<div key={pt.id} onClick={()=>{setSelPt(pt);setView("report");}} style={{padding:"0.875rem 1rem",background:"#fff",borderRadius:10,border:"0.5px solid #e0e0ee",marginBottom:8,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"space-between"}}>
          <div style={{display:"flex",alignItems:"center",gap:10}}>
            <div style={{width:38,height:38,borderRadius:"50%",background:BRAND_LIGHT,display:"flex",alignItems:"center",justifyContent:"center",fontSize:13,fontWeight:500,color:BRAND_MID}}>{pt.name.split(" ").map(n=>n[0]).join("").slice(0,2).toUpperCase()}</div>
            <div><p style={{fontSize:14,fontWeight:500,margin:0}}>{pt.name}</p><p style={{fontSize:12,color:"#555577",margin:0}}>{pt.age?`${pt.age} años · `:""}{pt.evaluations?.length||0} evaluaciones</p></div>
          </div>
          <i className="ti ti-chevron-right" style={{color:"#999",fontSize:18}}></i>
        </div>))}
      </div>)}
      {tab==="patients"&&view==="report"&&selPt&&<PatientReport patient={selPt} onBack={()=>setView("list")} onStartTCCI={()=>setView("tcci")} onScaleSelect={s=>{setActiveScale(s);setView("scale");}}/>}
      {tab==="patients"&&view==="tcci"&&selPt&&<TCCIPlan patient={selPt} onBack={()=>setView("report")}/>}
      {tab==="patients"&&view==="scale"&&activeScale&&<ScaleForm scale={activeScale} onComplete={handleScaleDone} onBack={()=>{setView("report");setActiveScale(null);}}/>}

      {tab==="scales"&&(<div>{!activeScale?(<><h2 style={{fontSize:16,fontWeight:500,marginBottom:"1rem"}}>Escalas validadas</h2>
        {Object.values(SCALES).map(s=>(<div key={s.id} style={{padding:"0.875rem 1rem",background:"#fff",borderRadius:10,border:"0.5px solid #e0e0ee",marginBottom:8,cursor:"pointer"}} onClick={()=>setActiveScale(s)}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <div><p style={{fontSize:14,fontWeight:500,margin:"0 0 3px"}}>{s.name}</p><p style={{fontSize:12,color:"#555577",margin:0}}>{s.desc}</p></div>
            <i className="ti ti-chevron-right" style={{color:"#999",fontSize:18,marginLeft:8}}></i>
          </div>
        </div>))}</>):(<ScaleForm scale={activeScale} onComplete={()=>setActiveScale(null)} onBack={()=>setActiveScale(null)}/>)}
      </div>)}

      {tab==="diagnostics"&&(<div>
        <h2 style={{fontSize:16,fontWeight:500,marginBottom:"0.5rem"}}>Diagnósticos — ICSD-3 TR · DSM-5-TR</h2>
        <p style={{fontSize:13,color:"#555577",marginBottom:"1rem"}}>{DX.length} patologías con criterios, escalas y nivel de evidencia.</p>
        <input value={diagSearch} onChange={e=>setDiagSearch(e.target.value)} placeholder="Buscar patología..." style={{width:"100%",padding:"8px 12px",fontSize:13,borderRadius:8,border:"0.5px solid #c8c8dd",background:"#fff",color:"#1a1a2e",marginBottom:"0.75rem"}}/>
        <div style={{display:"flex",flexWrap:"wrap",gap:6,marginBottom:"1rem"}}>{DIAG_CATS.map(c=>(<button key={c} onClick={()=>setDiagCat(c)} style={{padding:"4px 12px",fontSize:12,borderRadius:20,border:diagCat===c?`1.5px solid ${BRAND}`:"0.5px solid #c8c8dd",background:diagCat===c?BRAND_LIGHT:"#fff",color:diagCat===c?BRAND_MID:"#555577",cursor:"pointer",fontWeight:diagCat===c?500:400}}>{c}</button>))}</div>
        {fDx.map(d=>(<div key={d.id} style={{marginBottom:8,borderRadius:10,border:"0.5px solid #e0e0ee",overflow:"hidden"}}>
          <div onClick={()=>setExpDx(expDx===d.id?null:d.id)} style={{padding:"0.875rem 1rem",background:"#fff",cursor:"pointer",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <div style={{flex:1}}>
              <div style={{display:"flex",alignItems:"center",gap:6,flexWrap:"wrap"}}>
                <p style={{fontSize:14,fontWeight:500,margin:0}}>{d.name}</p>
                <span style={{fontSize:11,padding:"2px 8px",borderRadius:20,background:BRAND_LIGHT,color:BRAND_MID}}>{d.cat}</span>
                <span style={{fontSize:11,padding:"2px 8px",borderRadius:20,background:PC[d.evidence]+"22",color:PC[d.evidence]}}>Evidencia {d.evidence}</span>
              </div>
              <p style={{fontSize:12,color:"#555577",margin:"3px 0 0"}}>{d.def}</p>
            </div>
            <i className={`ti ${expDx===d.id?"ti-chevron-up":"ti-chevron-down"}`} style={{color:"#999",fontSize:16,marginLeft:8,flexShrink:0}}></i>
          </div>
          {expDx===d.id&&(<div style={{padding:"0 1rem 1rem",background:"#f4f4f8",borderTop:"0.5px solid #e0e0ee"}}>
            <div style={{marginTop:"0.875rem",display:"grid",gap:10}}>
              <div style={{padding:"0.75rem",background:"#fff",borderRadius:8,borderLeft:`3px solid ${BRAND}`}}><p style={{fontSize:12,fontWeight:500,color:BRAND_MID,margin:"0 0 4px"}}>Criterios ICSD-3 TR</p><p style={{fontSize:13,margin:0,lineHeight:1.6}}>{d.icsd}</p></div>
              {d.dsm&&<div style={{padding:"0.75rem",background:"#fff",borderRadius:8,borderLeft:`3px solid ${GREEN}`}}><p style={{fontSize:12,fontWeight:500,color:"#0F6E56",margin:"0 0 4px"}}>DSM-5-TR</p><p style={{fontSize:13,margin:0,lineHeight:1.6}}>{d.dsm}</p></div>}
              <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
                <div style={{flex:1,minWidth:140,padding:"0.75rem",background:"#fff",borderRadius:8,border:"0.5px solid #e0e0ee"}}><p style={{fontSize:12,fontWeight:500,margin:"0 0 6px",color:"#555577"}}>Escalas</p><div style={{display:"flex",flexWrap:"wrap",gap:4}}>{d.scales.map(s=><span key={s} style={{fontSize:11,padding:"2px 8px",borderRadius:20,background:BRAND_LIGHT,color:BRAND_MID}}>{s}</span>)}</div></div>
                <div style={{flex:1,minWidth:140,padding:"0.75rem",background:"#fff",borderRadius:8,border:"0.5px solid #e0e0ee"}}><p style={{fontSize:12,fontWeight:500,margin:"0 0 6px",color:"#555577"}}>Señales de alarma</p>{d.alarms.map((a,i)=><p key={i} style={{fontSize:12,margin:"2px 0",color:RED}}>• {a}</p>)}</div>
              </div>
              <p style={{fontSize:11,color:"#999",margin:0}}>Ref: {d.ref}</p>
            </div>
          </div>)}
        </div>))}
      </div>)}

      {tab==="tccd"&&(<div>
        <h2 style={{fontSize:16,fontWeight:500,marginBottom:"0.5rem"}}>TCC-I — Evidencia y componentes</h2>
        <div style={{padding:"0.875rem 1rem",background:BRAND_LIGHT,borderRadius:10,marginBottom:"1.25rem",border:`0.5px solid #AFA9EC`}}>
          <p style={{fontSize:13,fontWeight:500,color:BRAND_MID,margin:"0 0 4px"}}>Paquete óptimo — Furukawa et al. JAMA Psychiatry 2024</p>
          <p style={{fontSize:12,color:BRAND,margin:0}}>cNMA · 241 ensayos · 31,452 participantes · Reestructuración cognitiva (1.68) · Tercera ola (1.49) · Restricción del sueño (1.49) · Control de estímulos (1.43) · Presencial (1.83)</p>
        </div>
        {[{title:"Reestructuración cognitiva",ior:"1.68",col:BRAND,badge:"Mayor beneficio en remisión",desc:"Identifica y desafía creencias disfuncionales. Mejora calidad subjetiva y remisión a largo plazo."},
          {title:"Restricción del sueño",ior:"1.49",col:BRAND,badge:"Mejora eficiencia y WASO",desc:"Ventana = TTS promedio + 30 min. Ajuste semanal por ES. Reduce WASO (iMD −7 min)."},
          {title:"Tercera ola (Mindfulness/ACT)",ior:"1.49",col:BRAND,badge:"Aceptación",desc:"Mecanismo de aceptación, no de control. Atenúa la lucha contra el insomnio."},
          {title:"Control de estímulos",ior:"1.43",col:BRAND,badge:"Mejora latencia y eficiencia",desc:"5 reglas de Bootzin + regla de los 20 min. Mejora latencia (iMD −7 min)."},
          {title:"Formato presencial",ior:"1.83",col:GREEN,badge:"Formato óptimo",desc:"Formato más eficaz. Autoayuda con apoyo humano no fue significativamente inferior."},
          {title:"Higiene del sueño (aislada)",ior:"1.01",col:GRAY,badge:"Sin beneficio incremental",desc:"Sin beneficio como componente aislado. Contexto educativo únicamente."},
          {title:"Relajación",ior:"0.81",col:RED,badge:"Potencialmente contraproducente",desc:"Puede contrarrestar restricción del sueño y control de estímulos. Excluida del paquete óptimo."},
        ].map((c,i)=>(<div key={i} style={{marginBottom:10,padding:"1rem",background:"#f4f4f8",borderRadius:10}}>
          <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:6,marginBottom:6}}>
            <p style={{fontSize:14,fontWeight:500,margin:0}}>{c.title}</p>
            <div style={{display:"flex",gap:6}}><span style={{fontSize:11,padding:"2px 8px",borderRadius:20,background:c.col+"22",color:c.col}}>iOR {c.ior}</span><span style={{fontSize:11,padding:"2px 8px",borderRadius:20,background:c.col+"15",color:c.col}}>{c.badge}</span></div>
          </div>
          <p style={{fontSize:13,color:"#555577",margin:0,lineHeight:1.6}}>{c.desc}</p>
        </div>))}
        <div style={{marginTop:"1rem",padding:"0.875rem 1rem",background:BRAND_LIGHT,borderRadius:10,display:"flex",alignItems:"center",justifyContent:"space-between",gap:12,flexWrap:"wrap"}}>
          <p style={{fontSize:13,color:BRAND_MID,margin:0}}>El plan TCC-I sesión a sesión se genera en el expediente de cada paciente.</p>
          <button onClick={()=>setTab("patients")} style={{padding:"7px 14px",fontSize:12,borderRadius:8,border:"none",background:BRAND,color:"#fff",cursor:"pointer"}}>Ir a pacientes ↗</button>
        </div>
      </div>)}

      {tab==="formulas"&&(<div>
        <h2 style={{fontSize:16,fontWeight:500,marginBottom:"0.5rem"}}>Calculadoras clínicas</h2>
        <p style={{fontSize:13,color:"#555577",marginBottom:"1.25rem"}}>Fórmulas para el cálculo e interpretación clínica de parámetros del sueño.</p>
        {FORMULAS.map(f=>{const vals=fVals[f.id]||{};const res=fRes[f.id];return(<div key={f.id} style={{marginBottom:14,padding:"1rem 1.25rem",background:"#fff",borderRadius:10,border:"0.5px solid #e0e0ee"}}>
          <p style={{fontSize:14,fontWeight:500,margin:"0 0 4px"}}>{f.name}</p>
          <p style={{fontSize:12,color:"#555577",margin:"0 0 12px",lineHeight:1.5}}>{f.desc}</p>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(140px,1fr))",gap:8,marginBottom:10}}>
            {f.fields.map(field=>(<div key={field.id}>
              <p style={{fontSize:11,color:"#555577",margin:"0 0 4px"}}>{field.label}</p>
              <input placeholder={field.ph} value={vals[field.id]||""} onChange={e=>setFVals({...fVals,[f.id]:{...vals,[field.id]:e.target.value}})}
                style={{width:"100%",padding:"7px 10px",fontSize:13,borderRadius:8,border:"0.5px solid #c8c8dd",background:"#f4f4f8",color:"#1a1a2e"}}/>
            </div>))}
          </div>
          <button onClick={()=>calcF(f.id)} style={{padding:"7px 18px",fontSize:13,borderRadius:8,border:"none",background:BRAND,color:"#fff",cursor:"pointer",marginBottom:res?"12px":0}}>Calcular</button>
          {res&&(<div style={{padding:"1rem",background:"#f4f4f8",borderRadius:8,border:`1.5px solid ${BRAND}`}}>
            <div style={{display:"flex",alignItems:"baseline",gap:6,marginBottom:8}}>
              <span style={{fontSize:26,fontWeight:500,color:BRAND}}>{res.value}</span>
              {res.unit&&<span style={{fontSize:13,color:"#555577"}}>{res.unit}</span>}
            </div>
            <p style={{fontSize:12,color:"#555577",margin:0,lineHeight:1.7,whiteSpace:"pre-wrap"}}>{res.interp}</p>
          </div>)}
        </div>);})}
      </div>)}

      {tab==="glossary"&&(<div>
        <h2 style={{fontSize:16,fontWeight:500,marginBottom:"0.5rem"}}>Glosario de medicina del sueño</h2>
        <p style={{fontSize:13,color:"#555577",marginBottom:"1rem"}}>{GLOS.length} términos clínicos basados en ICSD-3 TR, AASM y literatura indexada.</p>
        <input value={glossSearch} onChange={e=>setGlossSearch(e.target.value)} placeholder="Buscar término..." style={{width:"100%",padding:"8px 12px",fontSize:13,borderRadius:8,border:"0.5px solid #c8c8dd",background:"#fff",color:"#1a1a2e",marginBottom:"1rem"}}/>
        {fGlos.map((g,i)=>(<div key={i} style={{padding:"0.75rem 1rem",marginBottom:6,background:"#fff",borderRadius:10,border:"0.5px solid #e0e0ee",display:"flex",gap:12,alignItems:"flex-start"}}>
          <span style={{fontSize:13,fontWeight:500,color:BRAND,minWidth:90,flexShrink:0}}>{g.t}</span>
          <span style={{fontSize:13,color:"#555577",lineHeight:1.6}}>{g.d}</span>
        </div>))}
      </div>)}
    </div>
  );
}

function mountApp(){ReactDOM.createRoot(document.getElementById("app-root")).render(React.createElement(App));}
</script>
</body>
</html>
