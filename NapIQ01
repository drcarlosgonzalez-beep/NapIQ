function calcPSQI(ans){
  const c1=ans["q6"]??null;
  let c2=null;
  if(ans["q2"]!==undefined&&ans["q5a"]!==undefined){const lat=Number(ans["q2"]);const ls=lat<=15?0:lat<=30?1:lat<=60?2:3;const raw=ls+(ans["q5a"]||0);c2=raw===0?0:raw<=2?1:raw<=4?2:3;}
  let c3=null;if(ans["q4"]!==undefined){const h=Number(ans["q4"]);c3=h>=7?0:h>=6?1:h>=5?2:3;}
  let c4=null;
  if(ans["q1"]&&ans["q3"]&&ans["q4"]!==undefined){
    const[bh,bm]=ans["q1"].split(":").map(Number);const[uh,um]=ans["q3"].split(":").map(Number);
    let bedMin=bh*60+bm,upMin=uh*60+um;if(upMin<=bedMin)upMin+=1440;
    const tec=(upMin-bedMin)/60;const eff=tec>0?(Number(ans["q4"])/tec)*100:0;
    c4=eff>=85?0:eff>=75?1:eff>=65?2:3;
  }
  let c5=null;const pk=["q5b","q5c","q5d","q5e","q5f","q5g","q5h","q5i","q5j"];
  const pv=pk.map(k=>ans[k]).filter(v=>v!==undefined);
  if(pv.length===pk.length){const sum=pv.reduce((s,v)=>s+v,0);c5=sum===0?0:sum<=9?1:sum<=18?2:3;}
  const c6=ans["q7"]??null;
  let c7=null;if(ans["q8"]!==undefined&&ans["q9"]!==undefined){const raw=(ans["q8"]||0)+(ans["q9"]||0);c7=raw===0?0:raw<=2?1:raw<=4?2:3;}
  const comps=[c1,c2,c3,c4,c5,c6,c7];
  const total=comps.every(c=>c!==null)?comps.reduce((s,c)=>s+c,0):null;
  return{c1,c2,c3,c4,c5,c6,c7,total};
}

