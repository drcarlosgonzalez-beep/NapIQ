          <p style={{fontSize:11,color:"#999",margin:0}}>Ref: {scale.ref}</p>
        </div>
      )}
      <button onClick={()=>score!==null&&onComplete({scaleId:scale.id,scaleName:scale.name,score,max:scale.max,label:interp.label,risk:interp.risk,date:new Date().toISOString()})}
        disabled={score===null} style={{padding:"10px 24px",borderRadius:8,border:"none",background:score!==null?BRAND:"#e0e0ee",color:"#fff",fontWeight:500,cursor:score!==null?"pointer":"not-allowed",fontSize:14}}>
        Guardar resultado
      </button>
    </div>
  );
}

function TCCIPlan({patient,onBack}){
  const le={};patient.evaluations?.forEach(e=>{le[e.scaleId]=e;});
  const isi=le["isi"]?.score??14;const psqi=le["psqi"]?.score??8;
  const sessions=buildSessions(isi,psqi);
  const [done,setDone]=useState(patient.tcciDone||{});
