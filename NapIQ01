const FORMULAS=[
  {id:"tts",name:"Tiempo Total de Sueño promedio (TTS)",desc:"Calcula el TTS promedio semanal a partir del diario de sueño.",
   fields:[{id:"d1",label:"TTS día 1 (h)",ph:"5.5"},{id:"d2",label:"TTS día 2 (h)",ph:"6.0"},{id:"d3",label:"TTS día 3 (h)",ph:"5.0"},{id:"d4",label:"TTS día 4 (h)",ph:"6.5"},{id:"d5",label:"TTS día 5 (h)",ph:"5.5"},{id:"d6",label:"TTS día 6 (h)",ph:"4.5"},{id:"d7",label:"TTS día 7 (h)",ph:"6.0"}],
   calc:v=>{const vals=Object.values(v).map(Number).filter(x=>!isNaN(x)&&x>0);if(vals.length<3)return null;const avg=vals.reduce((s,x)=>s+x,0)/vals.length;return{value:avg.toFixed(1),unit:"horas/noche",interp:avg>=7?"TTS normal (7-9h, AASM 2015). Verificar eficiencia del sueño.":avg>=6?`TTS leve-moderadamente reducido. Ventana de sueño inicial sugerida: ${(avg+0.5).toFixed(1)}h.`:`TTS significativamente reducido. Ventana sugerida: ${Math.max(5.5,avg+0.5).toFixed(1)}h (mínimo 5.5h). Alertar sobre somnolencia transitoria.`};}},
  {id:"es",name:"Eficiencia del Sueño (ES)",desc:"ES = (TTS ÷ TEC) × 100%. Meta terapéutica ≥85% en TCC-I.",
   fields:[{id:"tts",label:"TTS — horas dormidas",ph:"5.5"},{id:"tec",label:"TEC — tiempo en cama (h)",ph:"8.0"}],
   calc:v=>{const tts=Number(v.tts),tec=Number(v.tec);if(!tts||!tec)return null;const es=(tts/tec)*100;return{value:es.toFixed(1),unit:"%",interp:es>=90?"ES ≥90%: AUMENTAR ventana 15-20 min.":es>=85?"ES 85-89%: MANTENER ventana sin cambios.":es>=75?"ES 75-84%: MANTENER o reducir 15 min.":"ES <75%: REDUCIR ventana 15 min. Reforzar adherencia."};}},
  {id:"vs",name:"Ventana de Sueño inicial",desc:"Calcula la hora de acostarse prescrita según TTS promedio y hora de levantada fija.",
   fields:[{id:"tts",label:"TTS promedio (h)",ph:"5.2"},{id:"hl",label:"Hora de levantada (HH:MM)",ph:"06:30"}],
   calc:v=>{const tts=Number(v.tts);const[hh,mm]=(v.hl||"").split(":").map(Number);if(!tts||isNaN(hh)||isNaN(mm))return null;const vs=Math.max(5.5,tts+0.5);const hlMin=hh*60+mm;let hcMin=hlMin-(vs*60);if(hcMin<0)hcMin+=1440;const hcH=Math.floor(hcMin/60)%24,hcM=Math.round(hcMin%60);const hcStr=`${String(hcH).padStart(2,"0")}:${String(hcM).padStart(2,"0")}`;return{value:`${vs.toFixed(1)}h — Acostarse: ${hcStr}`,unit:"",interp:`Ventana: ${vs.toFixed(1)}h. Acostarse: ${hcStr}. Levantada fija: ${v.hl}.\nNO acostarse antes de las ${hcStr} aunque tenga sueño.`};}},
  {id:"ls",name:"Latencia de Sueño promedio (LS)",desc:"Tiempo promedio para conciliar el sueño. Punto de corte clínico >30 min.",
   fields:[{id:"d1",label:"LS día 1 (min)",ph:"45"},{id:"d2",label:"LS día 2 (min)",ph:"30"},{id:"d3",label:"LS día 3 (min)",ph:"60"},{id:"d4",label:"LS día 4 (min)",ph:"40"},{id:"d5",label:"LS día 5 (min)",ph:"55"},{id:"d6",label:"LS día 6 (min)",ph:"35"},{id:"d7",label:"LS día 7 (min)",ph:"50"}],
   calc:v=>{const vals=Object.values(v).map(Number).filter(x=>!isNaN(x)&&x>=0);if(vals.length<3)return null;const avg=vals.reduce((s,x)=>s+x,0)/vals.length;return{value:avg.toFixed(0),unit:"minutos",interp:avg<=15?"LS normal (≤15 min).":avg<=30?"LS levemente prolongada (15-30 min). Monitorear.":avg<=60?"LS prolongada (>30 min) — clínicamente significativa. Control de estímulos indicado.":"LS muy prolongada (>60 min). Control de estímulos + restricción del sueño prioritarios."};}},
  {id:"waso",name:"WASO promedio",desc:"Tiempo promedio despierto después de dormirse. Punto de corte: >30 min.",
   fields:[{id:"d1",label:"WASO día 1 (min)",ph:"60"},{id:"d2",label:"WASO día 2 (min)",ph:"45"},{id:"d3",label:"WASO día 3 (min)",ph:"90"},{id:"d4",label:"WASO día 4 (min)",ph:"30"},{id:"d5",label:"WASO día 5 (min)",ph:"75"},{id:"d6",label:"WASO día 6 (min)",ph:"50"},{id:"d7",label:"WASO día 7 (min)",ph:"40"}],
   calc:v=>{const vals=Object.values(v).map(Number).filter(x=>!isNaN(x)&&x>=0);if(vals.length<3)return null;const avg=vals.reduce((s,x)=>s+x,0)/vals.length;return{value:avg.toFixed(0),unit:"minutos",interp:avg<=20?"WASO normal (≤20 min).":avg<=30?"WASO limítrofe. Monitorear.":avg<=60?"WASO clínicamente significativo (>30 min). Restricción del sueño indicada (iMD −7 min, Furukawa 2024).":"WASO muy elevado (>60 min). Restricción + control de estímulos prioritarios. Descartar AOS."};}},
  {id:"imc",name:"Índice de Masa Corporal (IMC)",desc:"Relevante para tamizaje de AOS y Síndrome de Hipoventilación por Obesidad.",
   fields:[{id:"peso",label:"Peso (kg)",ph:"85"},{id:"talla",label:"Talla (m)",ph:"1.72"}],
   calc:v=>{const p=Number(v.peso),t=Number(v.talla);if(!p||!t)return null;const imc=p/(t*t);return{value:imc.toFixed(1),unit:"kg/m²",interp:imc<25?"Peso normal. Riesgo bajo para AOS por obesidad.":imc<30?"Sobrepeso. Riesgo moderado para AOS. Aplicar STOP-Bang.":imc<35?"Obesidad grado I. Riesgo elevado para AOS. STOP-Bang + poligrafía recomendada.":imc<40?"Obesidad grado II. Criterio STOP-Bang positivo (B+). Evaluación especializada.":"Obesidad grado III. Riesgo muy alto AOS severa y SHO. PSG/poligrafía urgente."};}},
  {id:"nnt",name:"NNT — Número Necesario a Tratar (TCC-I)",desc:"Cuántos pacientes tratar con TCC-I para que uno remita vs psicoeducación. Furukawa 2024.",
   fields:[{id:"cer",label:"Tasa de remisión control (0.0-1.0)",ph:"0.14"}],
   calc:v=>{const cer=Number(v.cer);if(!cer||cer<=0||cer>=1)return null;const or=5.34;const en=or*cer,ed=1-cer+en,eer=en/ed,rd=eer-cer,nnt=1/rd;return{value:nnt.toFixed(1),unit:"pacientes",interp:`Con CER ${(cer*100).toFixed(0)}%:\n• Tasa de remisión con TCC-I: ${(eer*100).toFixed(1)}%\n• Diferencia de riesgo: +${(rd*100).toFixed(1)}%\n• NNT: ${nnt.toFixed(1)} pacientes\nFuente: Furukawa Y et al. JAMA Psychiatry. 2024;81(4):357-365.`};}},
