<body>

<!-- LOGIN -->
<div id="login-screen">
  <div style="background:#fff;border-radius:16px;padding:40px 36px;width:340px;box-shadow:0 8px 40px rgba(0,0,0,0.18);text-align:center;">
    <div style="width:52px;height:52px;background:#534AB7;border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
      <i class="ti ti-moon" style="color:#fff;font-size:26px;"></i>
    </div>
    <h1 style="font-size:24px;font-weight:600;color:#1a1a2e;margin-bottom:4px;">NapIQ</h1>
    <p style="font-size:13px;color:#777;margin-bottom:28px;">Plataforma clínico-diagnóstica de medicina del sueño</p>
    <input id="pwd-input" type="password" placeholder="Contraseña de acceso"
      style="width:100%;padding:11px 14px;font-size:14px;border-radius:10px;border:1.5px solid #e0e0ee;margin-bottom:12px;"/>
    <button onclick="checkLogin()"
      style="width:100%;padding:11px;font-size:14px;font-weight:600;border-radius:10px;border:none;background:#534AB7;color:#fff;cursor:pointer;">
      Entrar
    </button>
    <p id="login-err" style="color:#A32D2D;font-size:12px;margin-top:10px;display:none;">Contraseña incorrecta.</p>
  </div>
</div>

<!-- APP -->
<div id="app-root" style="display:none;"></div>

<script>
function checkLogin(){
  const val=document.getElementById("pwd-input").value;
  const err=document.getElementById("login-err");
  if(val==="NapIQ2202"){
    document.getElementById("login-screen").style.display="none";
    document.getElementById("app-root").style.display="block";
    if(!window.__napiqMounted){window.__napiqMounted=true;mountApp();}
  } else {
    err.style.display="block";
    document.getElementById("pwd-input").value="";
    document.getElementById("pwd-input").focus();
  }
}
document.getElementById("pwd-input").addEventListener("keydown",e=>{if(e.key==="Enter")checkLogin();});
</script>

<script type="text/babel">
const {useState,useEffect,useRef}=React;

// ── STORAGE ───────────────────────────────────────────────────────────────────
function loadP(){try{const d=localStorage.getItem("napiq_pts");return d?JSON.parse(d):[];}catch{return[];}}
function saveP(pts){try{localStorage.setItem("napiq_pts",JSON.stringify(pts));}catch{}}

// ── PDF HELPERS ───────────────────────────────────────────────────────────────
const BRAND="#534AB7",BRAND_LIGHT="#EEEDFE",BRAND_MID="#3C3489";
const GREEN="#1D9E75",AMBER="#BA7517",RED="#A32D2D",GRAY="#888780";
function hexToRgb(h){return[parseInt(h.slice(1,3),16),parseInt(h.slice(3,5),16),parseInt(h.slice(5,7),16)];}
function pdfSetColor(doc,hex,type="fill"){const[r,g,b]=hexToRgb(hex);type==="fill"?doc.setFillColor(r,g,b):doc.setTextColor(r,g,b);}
function pdfHeader(doc,title,sub,name,date){
  const W=doc.internal.pageSize.getWidth();
  pdfSetColor(doc,BRAND,"fill");doc.rect(0,0,W,22,"F");
  doc.setFontSize(16);doc.setFont("helvetica","bold");pdfSetColor(doc,"#ffffff","text");doc.text("NapIQ",14,14);
  doc.setFontSize(9);doc.setFont("helvetica","normal");doc.text("Plataforma clínico-diagnóstica de medicina del sueño",52,10);
  doc.text(`Paciente: ${name}   |   Fecha: ${date}`,52,16);
  pdfSetColor(doc,BRAND_LIGHT,"fill");doc.rect(0,22,W,16,"F");
  doc.setFontSize(13);doc.setFont("helvetica","bold");pdfSetColor(doc,BRAND_MID,"text");doc.text(title,14,33);
  if(sub){doc.setFontSize(9);doc.setFont("helvetica","normal");pdfSetColor(doc,BRAND,"text");doc.text(sub,14,39);}
  return sub?44:40;
}
function pdfFooter(doc,p,t){
  const W=doc.internal.pageSize.getWidth(),H=doc.internal.pageSize.getHeight();
  pdfSetColor(doc,BRAND,"fill");doc.rect(0,H-10,W,10,"F");
  doc.setFontSize(7);doc.setFont("helvetica","normal");pdfSetColor(doc,"#ffffff","text");
  doc.text("NapIQ — Medicina del sueño basada en evidencia · ICSD-3 TR · DSM-5-TR",14,H-3.5);
  doc.text(`Página ${p} de ${t}`,W-30,H-3.5);
}
function pdfSectionTitle(doc,text,y){
  pdfSetColor(doc,BRAND,"fill");doc.rect(14,y,4,6,"F");
  doc.setFontSize(11);doc.setFont("helvetica","bold");pdfSetColor(doc,BRAND_MID,"text");doc.text(text,20,y+5);
  return y+10;
}
function pdfWrapped(doc,text,x,y,maxW,fs=10,color="#333333"){
  doc.setFontSize(fs);doc.setFont("helvetica","normal");pdfSetColor(doc,color,"text");
  const lines=doc.splitTextToSize(text,maxW);doc.text(lines,x,y);
  return y+lines.length*(fs*0.45+1.2)+2;
}
function pdfScoreBar(doc,name,score,max,color,x,y,bW){
  doc.setFontSize(8);doc.setFont("helvetica","bold");pdfSetColor(doc,BRAND_MID,"text");doc.text(name,x,y);
  pdfSetColor(doc,"#E8E8E8","fill");doc.roundedRect(x,y+2,bW,6,1,1,"F");
  const filled=Math.max(3,(score/max)*bW);const[r,g,b]=hexToRgb(color);
  doc.setFillColor(r,g,b);doc.roundedRect(x,y+2,filled,6,1,1,"F");
  doc.setFontSize(8);doc.setFont("helvetica","bold");pdfSetColor(doc,color,"text");doc.text(`${score}/${max}`,x+bW+3,y+7);
  return y+12;
}
function pdfCircle(doc,score,max,color,cx,cy,r){
  pdfSetColor(doc,"#E8E8E8","fill");doc.circle(cx,cy,r,"F");
  const steps=Math.round((score/max)*36);const[cr,cg,cb]=hexToRgb(color);doc.setFillColor(cr,cg,cb);
  for(let i=0;i<steps;i++){const a1=(i/36)*2*Math.PI-Math.PI/2,a2=((i+1)/36)*2*Math.PI-Math.PI/2;
    doc.triangle(cx,cy,cx+r*Math.cos(a1),cy+r*Math.sin(a1),cx+r*Math.cos(a2),cy+r*Math.sin(a2),"F");}
  doc.setFillColor(255,255,255);doc.circle(cx,cy,r*0.62,"F");
  doc.setFontSize(10);doc.setFont("helvetica","bold");pdfSetColor(doc,color,"text");
  doc.text(`${score}`,cx-(score>=10?3:1.5),cy+1.5);
  doc.setFontSize(6);doc.setFont("helvetica","normal");pdfSetColor(doc,GRAY,"text");doc.text(`/${max}`,cx+2,cy+4);
}

async function generatePatientReportPDF(patient,aiReport){
  const JsPDF=window.jspdf.jsPDF;
  const doc=new JsPDF({unit:"mm",format:"a4"});
  const W=doc.internal.pageSize.getWidth();
  const today=new Date().toLocaleDateString("es-MX",{year:"numeric",month:"long",day:"numeric"});
  const le={};patient.evaluations?.forEach(e=>{le[e.scaleId]=e;});
  const scaleInfo={
    psqi:{friendly:"Calidad de tu sueño",labelFn:v=>v<=5?"Tu sueño es de buena calidad":v<=10?"Tu sueño tiene algunas dificultades":"Tu sueño está pasando por un momento difícil",tip:"Este resultado refleja cómo ha sido tu sueño en el último mes, tomando en cuenta qué tan rápido te duermes, si te despiertas en la noche y cómo te sientes al día siguiente."},
    ess:{friendly:"Somnolencia durante el día",labelFn:v=>v<=10?"Tu nivel de somnolencia es normal":v<=12?"Tienes un poco más de somnolencia de lo usual":v<=17?"Tu somnolencia durante el día es elevada":"Tu somnolencia es muy alta — es importante evaluarla",tip:"Este resultado nos dice qué tanta probabilidad tienes de quedarte dormido/a en situaciones cotidianas. Un resultado alto puede indicar que tu sueño nocturno no está siendo reparador."},
    stopbang:{friendly:"Riesgo de apnea del sueño",labelFn:v=>v<=2?"Tu riesgo de apnea del sueño es bajo":v<=4?"Tienes un riesgo intermedio de apnea del sueño":"Tu riesgo de apnea del sueño es alto — se recomienda evaluación",tip:"La apnea del sueño ocurre cuando la respiración se interrumpe brevemente durante el sueño. Este cuestionario ayuda a identificar personas que podrían beneficiarse de un estudio de sueño."},
    isi:{friendly:"Severidad de tu insomnio",labelFn:v=>v<=7?"No tienes insomnio clínicamente significativo":v<=14?"Tienes insomnio leve — hay estrategias muy efectivas para manejarlo":v<=21?"Tu insomnio es moderado — el tratamiento puede ayudarte mucho":"Tu insomnio es severo — es importante que recibas tratamiento",tip:"El insomnio es una de las condiciones más tratables en medicina del sueño. La TCC-I tiene una efectividad superior al 80% en la remisión del insomnio crónico."},
    irls:{friendly:"Síndrome de piernas inquietas",labelFn:v=>v===0?"No presentas síntomas significativos":v<=10?"Tus síntomas son leves":v<=20?"Tus síntomas son moderados":v<=30?"Tus síntomas son severos":"Tus síntomas son muy severos",tip:"El síndrome de piernas inquietas es una condición neurológica con tratamientos muy efectivos disponibles."},
  };
  let y=pdfHeader(doc,"Reporte de sueño personalizado","Resumen de tu evaluación y próximos pasos",patient.name,today);
  y+=4;
  y=pdfWrapped(doc,`Hola ${patient.name.split(" ")[0]}, este reporte resume los resultados de tu evaluación de sueño. Está escrito en un lenguaje sencillo para que puedas entender cómo está tu sueño en este momento y qué podemos hacer juntos para mejorarlo.`,14,y,W-28,10,"#333333");
  y+=4;y=pdfSectionTitle(doc,"Tus resultados",y);
  const evals=Object.values(le);
  if(evals.length>0){
    const cR=10;const cSp=(W-28)/Math.min(evals.length,4);
    evals.slice(0,4).forEach((e,i)=>{
      const si=scaleInfo[e.scaleId];if(!si)return;
      const col=e.risk==="bajo"?GREEN:e.risk==="moderado"?AMBER:RED;
      const cx=14+cSp*i+cR+4;
      pdfCircle(doc,e.score,e.max,col,cx,y+cR,cR);
      doc.setFontSize(7);doc.setFont("helvetica","bold");pdfSetColor(doc,BRAND_MID,"text");
      const nm=doc.splitTextToSize(si.friendly,cSp-4);doc.text(nm,cx-(cSp/2-6),y+cR*2+5);
    });
    y+=cR*2+16;
    evals.forEach(e=>{
      const si=scaleInfo[e.scaleId];if(!si)return;
      const col=e.risk==="bajo"?GREEN:e.risk==="moderado"?AMBER:RED;
      if(y>240){doc.addPage();pdfFooter(doc,doc.internal.pages.length-1,doc.internal.pages.length);y=pdfHeader(doc,"Reporte de sueño personalizado","(continuación)",patient.name,today)+4;}
      pdfSetColor(doc,"#F9F9FF","fill");doc.roundedRect(14,y,W-28,28,2,2,"F");
      const[r,g,b]=hexToRgb(col);doc.setFillColor(r,g,b);doc.roundedRect(14,y,3,28,1,1,"F");
      let cy2=pdfScoreBar(doc,si.friendly,e.score,e.max,col,20,y+5,W-60)+2;
      doc.setFontSize(9);doc.setFont("helvetica","bold");pdfSetColor(doc,col,"text");doc.text(si.labelFn(e.score),20,cy2);cy2+=5;
      doc.setFontSize(8);doc.setFont("helvetica","normal");pdfSetColor(doc,"#555555","text");
      const tl=doc.splitTextToSize(si.tip,W-36);doc.text(tl,20,cy2);
      y+=28+4;
    });
  }
  if(aiReport&&aiReport.length>10){
    if(y>210){doc.addPage();pdfFooter(doc,doc.internal.pages.length-1,doc.internal.pages.length);y=pdfHeader(doc,"Reporte de sueño personalizado","Lo que dice tu médico",patient.name,today)+4;}
    y=pdfSectionTitle(doc,"Lo que dice tu médico",y);
    pdfSetColor(doc,"#F9F9FF","fill");doc.roundedRect(14,y,W-28,8,"F");
    doc.setFontSize(8);doc.setFont("helvetica","italic");pdfSetColor(doc,BRAND,"text");doc.text("El siguiente resumen fue elaborado por tu especialista en medicina del sueño:",17,y+5);y+=11;
    y=pdfWrapped(doc,aiReport,14,y,W-28,9,"#333333");
  }
  if(y>230){doc.addPage();pdfFooter(doc,doc.internal.pages.length-1,doc.internal.pages.length);y=pdfHeader(doc,"Reporte de sueño personalizado","Próximos pasos",patient.name,today)+4;}
  y+=4;y=pdfSectionTitle(doc,"Próximos pasos",y);
  ["Acude a tu próxima consulta con este reporte en mano.","Si te recetaron un plan de TCC-I, sigue las instrucciones de cada semana al pie de la letra.","Registra tu sueño cada mañana en tu diario de sueño — es la herramienta más importante del tratamiento.","Si tienes dudas o algo cambia, no esperes a tu próxima cita para comentarlo con tu médico.","Recuerda: el insomnio tiene tratamiento efectivo. Con constancia, los resultados llegan."].forEach((s,i)=>{
    pdfSetColor(doc,BRAND,"fill");doc.circle(17,y-1,2,"F");
    doc.setFontSize(9);pdfSetColor(doc,"#ffffff","text");doc.text(`${i+1}`,16,y);
    doc.setFontSize(9);pdfSetColor(doc,"#333333","text");
    const ls=doc.splitTextToSize(s,W-34);doc.text(ls,21,y);y+=ls.length*5+3;
  });
  const tp=doc.internal.pages.length-1;for(let p=1;p<=tp;p++){doc.setPage(p);pdfFooter(doc,p,tp);}
  doc.save(`NapIQ_Reporte_${patient.name.replace(/ /g,"_")}_${new Date().toISOString().slice(0,10)}.pdf`);
}

async function generateSessionPDF(patient,session){
  const JsPDF=window.jspdf.jsPDF;
  const doc=new JsPDF({unit:"mm",format:"a4"});
  const W=doc.internal.pageSize.getWidth();
  const today=new Date().toLocaleDateString("es-MX",{year:"numeric",month:"long",day:"numeric"});
  const titles={1:"Semana 1 — Entendiendo tu sueño",2:"Semana 2 — Regulando tu tiempo de sueño",3:"Semana 3 — Reconectando la cama con el sueño",4:"Semana 4 — Cambiando la forma en que piensas sobre el sueño",5:"Semana 5 — Desafiando los pensamientos difíciles",6:"Semana 6 — Aprendiendo a soltar la lucha",7:"Semana 7 — Consolidando tus avances",8:"Semana 8 — Manteniendo lo que lograste"};
  const intros={1:`Hola ${patient.name.split(" ")[0]}! Esta semana comenzamos juntos un camino para mejorar tu sueño. No se trata de hacer grandes cambios de un día para otro — se trata de entender cómo funciona tu sueño y empezar a observarlo con curiosidad, sin juicio.`,2:`¡Bienvenido/a a tu segunda semana! Esta semana ajustaremos el tiempo que pasas en cama. Puede sonar extraño, pero pasar MENOS tiempo en cama al principio es lo que hará que tu sueño se vuelva más profundo y continuo. ¡Confía en el proceso!`,3:`¡Vas muy bien! Esta semana añadimos una herramienta fundamental: aprender a usar la cama SOLO para dormir. Tu cerebro ha aprendido a asociar la cama con estar despierto/a y preocupado/a — esta semana empezamos a cambiar eso.`,4:`Esta semana llegamos al corazón del tratamiento: lo que piensas sobre el sueño. Los pensamientos negativos sobre el insomnio lo mantienen vivo. Esta semana empezarás a identificarlos — ¡sin juzgarte!`,5:`Esta semana aprenderás a cuestionar esos pensamientos difíciles y reemplazarlos por otros más útiles. No se trata de "pensar positivo" — se trata de pensar con más precisión y compasión hacia ti mismo/a.`,6:`Esta semana exploramos una forma diferente de relacionarte con el insomnio: en lugar de luchar contra él, aprender a observarlo y aceptarlo. Esto no significa resignarse — significa quitarle el poder que tiene sobre ti.`,7:`¡Estás en la recta final! Esta semana revisamos todo lo que has aprendido y construimos tu plan personal para mantener los avances.`,8:`¡Lo lograste! Esta sesión es tu revisión de mantenimiento. Vamos a ver cómo estás y asegurarnos de que tienes todo para seguir durmiendo bien.`};
  const motivations={1:"¡Un paso a la vez! Observar tu sueño esta semana es todo lo que necesitas hacer.",2:"La somnolencia la primera semana es normal — es señal de que el tratamiento está funcionando.",3:"Recuerda: levantarte de la cama cuando no puedes dormir no es rendirse — es la clave para mejorar.",4:"Identificar un pensamiento difícil ya es un gran avance. No te juzgues — solo observa.",5:"No se trata de pensar positivo, sino de pensar con más precisión. ¡Tú puedes!",6:"Soltar la lucha no es rendirse — es la forma más inteligente de ganar.",7:"Ya tienes las herramientas. Ahora es momento de confiar en ti mismo/a.",8:"¡Felicidades por llegar hasta aquí! Tu compromiso con mejorar tu sueño es admirable."};
  const ft=titles[session.n]||`Semana ${session.n}`;
  let y=pdfHeader(doc,ft,`Plan semanal para ${patient.name.split(" ")[0]}`,patient.name,today);y+=4;
  pdfSetColor(doc,BRAND_LIGHT,"fill");doc.roundedRect(14,y,W-28,24,2,2,"F");
  doc.setFontSize(10);doc.setFont("helvetica","normal");pdfSetColor(doc,BRAND_MID,"text");
  const il=doc.splitTextToSize(intros[session.n]||`Esta semana trabajaremos en: ${session.focus}`,W-34);
  doc.text(il,18,y+7);y+=Math.max(26,il.length*5+8);y+=4;
  if(session.content?.length>0){
    y=pdfSectionTitle(doc,"Tus instrucciones para esta semana",y);
    const fh={"Modelo 3P de Spielman":"¿Por qué te quedas sin dormir? El ciclo del insomnio","Cómo usar el Diario de Sueño":"Tu diario de sueño — cómo llenarlo cada mañana","Cómo calcular la ventana de sueño inicial":"Tu horario de sueño personalizado","Protocolo de titulación semanal":"Cómo ajustamos tu horario semana a semana","Las 5 reglas de control de estímulos (Bootzin, 1972)":"Tus 5 reglas para esta semana","Manejo de resistencias comunes":"Respuestas a tus posibles dudas","Modelo cognitivo del insomnio (Harvey, 2002)":"¿Cómo los pensamientos mantienen el insomnio?","Técnica: Registro de 3 columnas":"Tu ejercicio de la semana","Cuestionamiento socrático — 5 preguntas clave":"Las 5 preguntas para cuestionar tus pensamientos","Paradoja del control del sueño":"¿Por qué esforzarte por dormir lo empeora?","Diferencia conceptual: control vs aceptación":"Una nueva forma de ver el insomnio","Defusión cognitiva":"Observar tus pensamientos desde lejos","Mindfulness pre-sueño (5-10 min)":"Tu práctica de mindfulness esta semana","Revisión de progreso":"Revisando cuánto has avanzado","Plan personal de mantenimiento":"Tu plan personal para seguir durmiendo bien","Evaluación de mantenimiento":"Cómo está tu sueño ahora"};
    session.content.forEach((c,ci)=>{
      if(y>240){doc.addPage();pdfFooter(doc,doc.internal.pages.length-1,doc.internal.pages.length);y=pdfHeader(doc,ft,"(continuación)",patient.name,today)+8;}
      doc.setFontSize(10);doc.setFont("helvetica","bold");pdfSetColor(doc,BRAND_MID,"text");
      doc.text(`${ci+1}. ${fh[c.heading]||c.heading}`,14,y);y+=6;
      const fb=c.body.replace(/TTS/g,"horas dormidas").replace(/\bTEC\b/g,"tiempo en cama").replace(/\bES\b/g,"eficiencia del sueño").replace(/WASO/g,"tiempo despierto en la noche").replace(/hiperarousal/g,"estado de alerta elevada").replace(/iOR[\s\d.]+/g,"").replace(/IC 95%[^)]+\)/g,"").replace(/Furukawa[^.]+\./g,"").replace(/Harvey[^.]+\./g,"").replace(/Bootzin[^,]+,/g,"").replace(/Borbely[^.]+\./g,"").trim();
      const bl=doc.splitTextToSize(fb,W-28);
      doc.setFontSize(9);doc.setFont("helvetica","normal");pdfSetColor(doc,"#333333","text");
      let li=0;
      while(li<bl.length){
        if(y>255){doc.addPage();pdfFooter(doc,doc.internal.pages.length-1,doc.internal.pages.length);y=pdfHeader(doc,ft,"(continuación)",patient.name,today)+8;}
        const chunk=bl.slice(li,li+12);doc.text(chunk,14,y);y+=chunk.length*4.5;li+=12;
      }
      y+=4;
    });
  }
  if(session.tarea){
    if(y>230){doc.addPage();pdfFooter(doc,doc.internal.pages.length-1,doc.internal.pages.length);y=pdfHeader(doc,ft,"Tu tarea",patient.name,today)+8;}
    y+=2;pdfSetColor(doc,BRAND,"fill");doc.roundedRect(14,y,W-28,8,2,2,"F");
    doc.setFontSize(10);doc.setFont("helvetica","bold");pdfSetColor(doc,"#ffffff","text");doc.text("Tu tarea de esta semana",17,y+5.5);y+=10;
    pdfSetColor(doc,BRAND_LIGHT,"fill");doc.roundedRect(14,y,W-28,30,2,2,"F");
    doc.setFontSize(9);doc.setFont("helvetica","normal");pdfSetColor(doc,BRAND_MID,"text");
    const tl=doc.splitTextToSize(session.tarea.replace(/TTS/g,"horas dormidas").replace(/\bTEC\b/g,"tiempo en cama").replace(/\bES\b/g,"eficiencia del sueño"),W-32);
    doc.text(tl,17,y+6);y+=Math.max(32,tl.length*4.5+8);
  }
  // Diario for sessions 1-2
  if(session.n<=2){
    if(y>180){doc.addPage();pdfFooter(doc,doc.internal.pages.length-1,doc.internal.pages.length);y=pdfHeader(doc,ft,"Diario de sueño",patient.name,today)+8;}
    y+=4;y=pdfSectionTitle(doc,"Tu diario de sueño — esta semana",y);
    const days=["Lun","Mar","Mié","Jue","Vie","Sáb","Dom"];
    const headers=["Día","Acosté","Tardé","Despertares","T.Despierto","Levanté","Hrs dormidas","Calidad 0-10"];
    const cW=(W-28)/headers.length;const rH=8;
    pdfSetColor(doc,BRAND,"fill");doc.rect(14,y,W-28,rH,"F");
    headers.forEach((h,i)=>{doc.setFontSize(6);doc.setFont("helvetica","bold");pdfSetColor(doc,"#ffffff","text");doc.text(h,14+i*cW+1,y+5);});
    y+=rH;
    days.forEach((d,i)=>{
      pdfSetColor(doc,i%2===0?"#F5F5FF":BRAND_LIGHT,"fill");doc.rect(14,y,W-28,rH,"F");
      doc.setFontSize(8);doc.setFont("helvetica","bold");pdfSetColor(doc,BRAND_MID,"text");doc.text(d,15,y+5.5);
